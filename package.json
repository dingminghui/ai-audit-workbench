{
	"name": "ai-audit-workbench",
	"version": "0.0.0",
	"description": "一个基于 Vite 的 React 项目",
	"type": "module",
	"private": true,
	"scripts": {
		"dev": "vite --open --mode native",
		"dev:local": "vite --open --mode native",
		"build": "vite build --mode prod",
		"build:local": "vite build --mode native",
		"preview": "vite preview",
		"test": "vitest",
		"test:ci": "vitest run",
		"lint:tsc": "tsc -b",
		"lint:eslint": "eslint . --max-warnings 0",
		"lint:eslint:fix": "eslint . --max-warnings 0 --fix",
		"lint:style": "stylelint \"**/*.css\"",
		"lint:style:fix": "stylelint \"**/*.css\" --fix",
		"lint": "pnpm run lint:tsc && pnpm run lint:eslint && pnpm run lint:style",
		"lint:fix": "pnpm run lint:eslint:fix && pnpm run lint:style:fix",
		"format": "prettier --write .",
		"validate": "pnpm run lint && pnpm run test:ci"
	},
	"dependencies": {
		"@radix-ui/react-dropdown-menu": "^2.1.16",
		"@react-pdf-viewer/core": "3.12.0",
		"@react-pdf-viewer/get-file": "3.12.0",
		"@react-pdf-viewer/highlight": "3.12.0",
		"@react-pdf-viewer/page-navigation": "3.12.0",
		"@react-pdf-viewer/thumbnail": "3.12.0",
		"@react-pdf-viewer/zoom": "3.12.0",
		"@tanstack/react-query": "^5.90.10",
		"@tanstack/react-query-devtools": "^5.91.0",
		"pdfjs-dist": "3.4.120",
		"react": "^19.2.0",
		"react-dom": "^19.2.0",
		"react-error-boundary": "^6.0.0",
		"react-image-crop": "^11.0.10",
		"react-markdown": "^10.1.0",
		"react-router": "^7.9.6",
		"react-zoom-pan-pinch": "^3.7.0",
		"remark-gfm": "^4.0.1"
	},
	"devDependencies": {
		"@eslint/js": "^9.17.0",
		"@tailwindcss/vite": "^4.1.17",
		"@testing-library/dom": "^10.4.1",
		"@testing-library/jest-dom": "^6.9.1",
		"@testing-library/react": "^16.3.0",
		"@testing-library/user-event": "^14.6.1",
		"@types/react": "^19.2.6",
		"@types/react-dom": "^19.2.3",
		"@vitejs/plugin-react": "^5.1.1",
		"@vitest/coverage-v8": "^4.0.13",
		"eslint": "^9.17.0",
		"eslint-config-prettier": "^10.0.1",
		"eslint-plugin-jsx-a11y": "^6.10.2",
		"eslint-plugin-react": "^7.37.2",
		"eslint-plugin-react-hooks": "^5.0.0",
		"happy-dom": "^20.0.10",
		"prettier": "^3.4.2",
		"prettier-plugin-organize-imports": "^4.1.0",
		"prettier-plugin-tailwindcss": "^0.6.9",
		"stylelint": "^16.24.0",
		"stylelint-config-standard": "^39.0.1",
		"tailwindcss": "^4.1.17",
		"typescript": "^5.9.3",
		"typescript-eslint": "^8.18.0",
		"vite": "^7.2.4",
		"vitest": "^4.0.13"
	}
}
